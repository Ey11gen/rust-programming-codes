// Chapter 2 — Exercise: Constants in Practice

const SECONDS_PER_MINUTE: u64 = 60;
const MINUTES_PER_HOUR:   u64 = 60;
const HOURS_PER_DAY:       u64 = 24;
const DAYS_PER_YEAR:       u64 = 365;
const SPEED_OF_LIGHT_MS:   u64 = 299_792_458;

fn main() {
    let seconds_per_year = SECONDS_PER_MINUTE * MINUTES_PER_HOUR
        * HOURS_PER_DAY * DAYS_PER_YEAR;
    println!("Seconds per year: {seconds_per_year}");

    let light_per_year: u128 = SPEED_OF_LIGHT_MS as u128
        * seconds_per_year as u128;
    println!("Light travels {} meters per year", light_per_year);
}
